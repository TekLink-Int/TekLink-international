# ─── Resend (email notifications) ────────────────────────────────────────────
# Get your key at https://resend.com — free tier: 3,000 emails/month
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# "From" address. Must be from a domain verified in your Resend account.
# Until teklink.com.au is verified, use: onboarding@resend.dev (Resend default)
RESEND_FROM_EMAIL=TekLink <noreply@teklink.com.au>

# Where contact form notifications are delivered
CONTACT_EMAIL_TO=info@teklinkinternational.com

# ─── Google Sheets ────────────────────────────────────────────────────────────
# 1. Create a Google Cloud project → enable the Sheets API
# 2. Create a Service Account → download the JSON key
# 3. Share your Google Sheet with the service account email (Editor access)
# 4. Fill in the values below from the JSON key file

GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SHEETS_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Copy the private_key value from the JSON key (keep the \n escape sequences)
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ─── Sheet setup ──────────────────────────────────────────────────────────────
# Create two tabs in your spreadsheet:
#   "Contact" with headers: Timestamp | Name | Company | Email | Type | Platform | Message
#   "Notify"  with headers: Timestamp | Email
